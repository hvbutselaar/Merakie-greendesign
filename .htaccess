# Meraki green design — Hostinger (Apache/LiteSpeed)
RewriteEngine On

# www -> non-www (canonical: https://meraki-greendesign.nl) — single hop to https + apex
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# HTTP -> HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Renamed project slugs (301, keeps old links/bookmarks working) ---
RewriteRule ^nike/?$ /kantoorbeplanting-uddel/ [L,R=301]
RewriteRule ^sth/?$ /kantoorbeplanting-nijkerk/ [L,R=301]

# Nette 404-pagina in de huisstijl
ErrorDocument 404 /404.html

# ---------------------------------------------------------------- SECURITY HEADERS
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---------------------------------------------------------------- COMPRESSION
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------------------------------------------------------------- CACHING
# Images rarely change in place (filenames are per-spot unique) -> cache long.
# CSS/JS are edited in place with no cache-busting -> keep short so updates propagate.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType text/css                "access plus 7 days"
  ExpiresByType application/javascript  "access plus 7 days"
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Long-lived, safe-to-revalidate cache for static images
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  # Shorter cache for in-place-edited assets (no version hashing yet)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
